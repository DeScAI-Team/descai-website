VITE_ARWEAVE_INDEX_API_URL=/api/index
VITE_ARWEAVE_GATEWAY_URL=https://arweave.net
VITE_DEFILLAMA_BASE_URL=https://coins.llama.fi
MOLECULE_API_KEY=
MOLECULE_GRAPHQL_ENDPOINT=https://production.graphql.api.molecule.xyz/graphql
# Snapshot + donation addresses for the snapshots page (Vite client).
# Prefer VITE_SNAPSHOT_*; if empty, unprefixed keys below are injected at dev/build time.
VITE_SNAPSHOT_ETH_WALLET_ADDRESS=
VITE_SNAPSHOT_RPC=
VITE_SNAPSHOT_BUCKET=
VITE_SNAPSHOT_ARWEAVE_WALLET=
VITE_SNAPSHOT_AKT_WALLET=
ETH_WALLET_ADDRESS=
RPC=
SNAPSHOT_BUCKET=
ARWEAVE_WALLET_ADDRESS=
# Same wallet as above — used by home sidebar + search index (via index-api)
# VITE_ARWEAVE_OVERVIEW_AGENT_ADDRESS=
AKT_WALLET_ADDRESS=
# Akash deployment job (jobs/deploy-test.mjs; scheduler in jobs/deploy-cron.mjs + npm start)
# CLI: npm run deploy:test
#      npm run deploy:test -- --dry-run
#      npm run deploy:test -- --skip-d1
#      npm run deploy:test -- --no-sdl-fit
#      npm run h100:check          # see H100 provider availability vs deploy SDL
#      npm run h100:check -- --json
AKASH_MNEMONIC=
AKASH_RPC=https://rpc.akashnet.net:443
AKASH_GRPC=https://akash-grpc.publicnode.com:443
# Parallel race: low deposit per GPU card to find bids ($2 ACT default).
AKASH_PARALLEL_DEPOSIT_UACT=2000000
# Winner lease: total escrow after top-up ($30 ACT default; topped up after bid wins).
AKASH_WINNER_DEPOSIT_UACT=30000000
# BME AKT→ACT mint settlement wait before deploy proceeds (default 30 min).
# AKASH_ACT_MINT_TIMEOUT_MS=1800000
# AKASH_ACT_MINT_POLL_INTERVAL_MS=10000
# Stale open deployments are closed at startup to return escrow to your wallet.
AKASH_MAX_USD_PER_HOUR=2.80
# Parallel GPU cards: h100 sxm/pcie, h200 sxm — first bid wins
# AKASH_SDL_CPU_UNITS=38
# AKASH_SDL_MEMORY_GB=64
# AKASH_SDL_STORAGE_GI=128
# Optional manual AKT/USD override when CoinGecko is unavailable
AKASH_AKT_USD_PRICE=
# AKASH_BID_MAX_WAIT_MS=30000        # 30s bid window per SDL attempt (default)
# AKASH_BID_POLL_INTERVAL_MS=10000
# AKASH_LEASE_READY_TIMEOUT_MS=600000
# AKASH_LEASE_POLL_INTERVAL_MS=10000
# AKASH_KEEPALIVE_MS=1800000   # used with --skip-d1 only
# 1claw — fetch Akash age decrypt keys (jobs/key-fetch-test.mjs, deploy-test)
# Use agent key (ocv_...) for deploy; personal key (1ck_...) works for local testing.
ONECLAW_API_KEY=
# ONECLAW_AGENT_API_KEY=   # alias for ONECLAW_API_KEY
ONECLAW_VAULT_ID=
ONECLAW_AGENT_ID=
# ONECLAW_BASE_URL=https://api.1claw.xyz
# ONECLAW_SECRET_PATHS=akash/AGE_SECRET_KEY_ENV,akash/AGE_SECRET_KEY_ARWEAVE
# Cloudflare D1 — agent orchestrator status (deploy closes on status=done)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=9b6bc07b-fce1-42bf-b813-2c7e1670d9ae
# D1_POLL_INTERVAL_MS=15000
# D1_MAX_WAIT_MS=7200000